# env / secrets
.env
.env.local
.env.*.local
*.pem
*.key

# node / next
node_modules
.next
out
dist
.turbo
*.tsbuildinfo
.vercel

# os
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editors
.vscode/*
!.vscode/extensions.json
.idea
*.swp

# scratch / probes
scripts/_probe-out/
*.probe.json

# rendered print-size PNGs (huge, regenerated on demand at sync time)
public/designs/*-light.png
public/designs/*-dark.png
!public/designs/*-preview-light.png
!public/designs/*-preview-dark.png

# Mockups: keep Printify-mirrored mockups in repo so the storefront
# works out-of-the-box on git clone — the only ones we exclude are
# any temp/probe scratch.

# Printify sync intermediates — keep canonical mapping committed,
# exclude the rest.
data/*
!data/products.json
